# Enable URL rewriting
RewriteEngine On

# Allow .env access denial
<Files "\.env">
    Require all denied
</Files>

# Protect logs directory
RewriteRule ^logs/ - [F,L]

# Protect app directory internals
RewriteRule ^app/ - [F,L]

# Protect database directory
RewriteRule ^database/ - [F,L]

# Front controller — all requests go to index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Default charset
AddDefaultCharset UTF-8

# ===== Performance: Gzip compression (only if mod_deflate loaded) =====
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ===== Performance: Cache static assets (only if mod_expires loaded) =====
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresDefault "access plus 1 hour"
</IfModule>

# ===== Security headers (only if mod_headers loaded) =====
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
