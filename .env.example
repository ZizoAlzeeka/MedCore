# ===== Platform Configuration =====
# App Settings
APP_NAME=منصة كشف التحاليل المكررة
APP_URL=http://127.0.0.1:8000
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=Asia/Riyadh
APP_LANG=ar

# ===== Database Driver =====
# Supported: sqlite | mysql
# To switch from sqlite to mysql:
#   1. Set DB_DRIVER=mysql
#   2. Configure DB_HOST/PORT/NAME/USER/PASS below
#   3. Delete database/platform.sqlite (optional, harmless)
#   4. Run install.php again to create MySQL tables
DB_DRIVER=sqlite

# SQLite settings (used only when DB_DRIVER=sqlite)
# Path is relative to project root, or absolute. Leave empty for default.
DB_PATH=database/platform.sqlite

# MySQL settings (used only when DB_DRIVER=mysql)
DB_HOST=YOUR_DB_HOST
DB_PORT=3306
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_NAME
DB_PASS=YOUR_DB_PASSWORD
DB_CHARSET=utf8mb4

# Security
CSRF_ENABLED=true
SESSION_LIFETIME=7200

# Defaults
DEFAULT_DUP_WINDOW_DAYS=30
DEFAULT_LANG=ar
